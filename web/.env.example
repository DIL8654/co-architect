# CoArchitect AI Frontend Environment Variables
#
# Runtime values are loaded from ../backend/.env via Vite envDir.
# Keep local credentials and local runtime values in backend/.env only.

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:5010

# Optional deployment override used in CI/CD only.
# For GitLab deployment, set this as a GitLab variable instead of committing real URLs here.
VITE_API_BASE_URL_PROD=

# Application Environment
VITE_APP_ENV=development
