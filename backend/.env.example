# Docker Compose host port overrides
API_PORT=5010
VITE_API_BASE_URL=http://localhost:5010
VITE_APP_ENV=development
POSTGRES_PORT=5432
AZURITE_BLOB_PORT=10000
AZURITE_QUEUE_PORT=10001

# Use Mock for the lowest-cost local MVP. Set TiDB or Postgres for cloud-backed local testing.
DATASTORE_PROVIDER=Mock
DATABASE_CONNECTION_STRING=
POSTGRES_CONNECTION_STRING=Host=postgres;Database=coarchitect;Username=postgres;Password=postgres

# Use None for local mock storage. Set AzureBlobSas with a container SAS URL stored outside git.
ARCHITECTURE_STORAGE_PROVIDER=None
ARCHITECTURE_STORAGE_CONTAINER_SAS_URL=

# Mock keeps smoke tests cheap. Set AzureFoundry when testing the real agent.
ARCHITECTURE_AGENT_PROVIDER=Mock
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=
AZURE_AI_FOUNDRY_AGENT_ID=
AZURE_AI_FOUNDRY_MODEL_DEPLOYMENT=
AZURE_AI_FOUNDRY_API_VERSION=2025-04-01-preview
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_BEARER_TOKEN=
